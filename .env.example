# ─────────────────────────────────────────────
# AI Work Hub — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# ── Required ─────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/workhub

# ── Optional — AI Features ───────────────────

# OpenAI API key for AI Daily Brief, Project Summary,
# Task Extraction, and Copilot features.
# If not set, all AI features fall back to heuristic/static responses.
# The app is fully usable without this key.
OPENAI_API_KEY=

# ── Required for n8n Automation ──────────────

# Secret token for protecting the automation webhook routes.
# n8n sends this as: Authorization: Bearer <secret>
# If not set, all /api/automation/* routes will reject with 403.
# Use a long random string (e.g. openssl rand -hex 32).
AUTOMATION_SECRET=
